# ------------------------------------------------------------------------------
# OpenAI-compatible LLM configuration
# ------------------------------------------------------------------------------
# Required for:
# - structured query extraction
# - clarification / follow-up question generation
# - new case import from raw jsonl
OPENAI_API_KEY=your_api_key_here

# Compatible endpoint, e.g. OpenAI / DashScope / DeepSeek / vLLM
OPENAI_API_BASE=https://api.openai.com/v1

# Model used for JSON-style extraction and judgment
OPENAI_MODEL=gpt-4.1-mini

# Optional request timeout in seconds
OPENAI_TIMEOUT_SECONDS=30

# Keep enabled for providers that support JSON mode
OPENAI_USE_JSON_MODE=1


# ------------------------------------------------------------------------------
# Retrieval / ranker configuration
# ------------------------------------------------------------------------------
# Candidate store backend: auto | lancedb | sqlite
CASEMATCH_DB_BACKEND=auto

# Primary vector database location
CASEMATCH_LANCEDB_URI=data/cases.lancedb

# Default reranker: simple | bm25 | bge_m3 | hybrid
CASEMATCH_RANKER=hybrid

# Local or remote BGE-M3 model path
CASEMATCH_BGE_MODEL_PATH=BAAI/bge-m3

# BGE inference options
CASEMATCH_BGE_USE_FP16=1
CASEMATCH_BGE_BATCH_SIZE=32
CASEMATCH_BGE_MAX_LENGTH=4096

# Hybrid weights
# If CASEMATCH_HYBRID_FE_WEIGHT / CASEMATCH_HYBRID_LC_WEIGHT are empty,
# CASEMATCH_HYBRID_BM25_WEIGHT will be used as their shared fallback.
CASEMATCH_HYBRID_BGE_WEIGHT=1.0
CASEMATCH_HYBRID_BM25_WEIGHT=0.45
CASEMATCH_HYBRID_FE_WEIGHT=0.1
CASEMATCH_HYBRID_LC_WEIGHT=0.2


# ------------------------------------------------------------------------------
# Runtime / serving configuration
# ------------------------------------------------------------------------------
# Optional GPU selection, e.g. 0 or 0,1
CUDA_DEVICES=0

# Gradio server
CASEMATCH_GRADIO_HOST=127.0.0.1
CASEMATCH_GRADIO_PORT=7860


# ------------------------------------------------------------------------------
# Hugging Face data distribution
# ------------------------------------------------------------------------------
# Put the dataset repo id here after you upload the `data/` contents to HF.
# Recommended repo_type is `dataset`.
CASEMATCH_HF_REPO_ID=Yuel-P/CaseMatch-Agent-data
CASEMATCH_HF_REPO_TYPE=dataset
CASEMATCH_HF_REVISION=main

# Local target directory. The HF repo should mirror the local `data/` layout.
CASEMATCH_HF_LOCAL_DIR=data

# Optional:
# - use HF_TOKEN when the repo is private
# - leave empty for public datasets
HF_TOKEN=
